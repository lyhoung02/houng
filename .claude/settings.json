{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/lyhoung/.local/bin/graphify hook-guard search"
          }
        ]
      },
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/lyhoung/.local/bin/graphify hook-guard read"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "(cd /Users/lyhoung/Personal/houng && /Users/lyhoung/.local/bin/graphify update . >/dev/null 2>&1 &)"
          }
        ]
      }
    ]
  }
}